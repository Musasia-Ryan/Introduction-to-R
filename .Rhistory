interview_date, study_arm) |>
mutate(interview_date = as_date(interview_date)),
by = c("number_0" = "number")
) |>
mutate(visit_type = "Quarterly Follow-up")
# quarterly recruited children
child_anthro_quart_recruit_raw <- read_csv("/Users/cema/Documents/cema/Muema/L4H_diet_diversity/L4H_Quarterly individual questionnaire/Repeat- chldrnquestns1.csv",
na = "---") |>
rename_all(~ str_replace(., "^form.chldrnquestns.", "")) |>
clean_names()
child_anthro_quart_recruit <- child_anthro_quart_recruit_raw |>
select(
number_0, chld_dob, gendrchld,
any_of(c("chldhght", "chldwght", "chld_muac")),
brstfd, hlthprblmschld
) |>
distinct() |>
left_join(
quart_hh_raw |>
select(number, household_id, village, sublocation,
interview_date, study_arm) |>
mutate(interview_date = as_date(interview_date)),
by = c("number_0" = "number")
) |>
mutate(visit_type = "Quarterly Follow-up")
# a gender lookup table from all datasets that recorded gender
# gender was only collected at baseline and at recruitment visits,
# so we use this table to fill it in for data where it is missing
gender_lookup <- bind_rows(
child_baseline_joined    |> select(number_0, chld_dob, household_id, gendrchld),
child_anthro_six_recruit |> select(number_0, chld_dob, household_id, gendrchld),
child_anthro_quart_recruit |> select(number_0, chld_dob, household_id, gendrchld)
) |>
filter(!is.na(gendrchld)) |>
distinct(number_0, chld_dob, household_id, .keep_all = TRUE)
# combine all datasets and fill gender, to calculate anthropometric status
child_nutritional_status <- bind_rows(
child_baseline_joined,
child_anthro_six,
child_anthro_six_recruit,
child_anthro_quart,
child_anthro_quart_recruit
) |>
# fill missing gender from the lookup table
left_join(
gender_lookup |> rename(gendrchld_lookup = gendrchld),
by = c("number_0", "chld_dob", "household_id")
) |>
mutate(gendrchld = coalesce(gendrchld, gendrchld_lookup)) |>
select(-gendrchld_lookup) |>
mutate(
chld_dob       = as.Date(chld_dob),
interview_date = as.Date(interview_date)
) |>
group_by(household_id, chld_dob) |>
fill(gendrchld, .direction = "downup") |>
ungroup() |>
mutate(
gendrchld  = ifelse(gendrchld == 1, "m", "f"),
# age in  months
age_months = round(as.numeric(interview_date - chld_dob) / 30),
# classify into standard age groups
age_group  = case_when(
age_months <  6  ~ "Infant < 6 months",
age_months <  24 ~ "Children 6 - 23 months",
age_months <= 59 ~ "Children 24 - 59 months",
TRUE ~ NA_character_
),
measure = ifelse(age_months < 24, "l", "h")
) |>
filter(!age_group %in% "Infant < 6 months") |>
filter(!is.na(chld_dob)) |>
# ── WHZ: Weight-for-Height Z-score ──────────────────────────────────────
# WHZ < -2 = Moderate Acute Malnutrition (MAM)
# WHZ < -3 = Severe Acute Malnutrition (SAM)
mutate(
whz = anthro_zscores(
sex     = gendrchld,
weight  = chldwght,
lenhei  = chldhght,
measure = measure
)$zwfl
) |>
# ── HAZ: Height-for-Age Z-score ─────────────────────────────────────────
# HAZ < -2 = Moderate stunting
# HAZ < -3 = Severe stunting
mutate(
haz = anthro_zscores(
sex     = gendrchld,
age     = age_months,
lenhei  = chldhght,
measure = measure
)$zlen
) |>
# Malnutrition classification using WHZ
mutate(
malnutrition_whz = case_when(
whz <  -3 ~ "Severe Acute Malnutrition (SAM)",
whz >= -3 & whz < -2  ~ "Moderate Acute Malnutrition (MAM)",
whz >= -2 ~ "Normal",
TRUE ~ NA_character_
)
) |>
# Malnutrition classification using MUAC
mutate(
malnutrition_muac = case_when(
chld_muac <  11.5 ~ "Severe Acute Malnutrition (SAM)",
chld_muac >= 11.5 & chld_muac <  12.5   ~ "Moderate Acute Malnutrition (MAM)",
chld_muac >= 12.5 ~ "Normal",
TRUE ~ NA_character_
)
) |>
# malnutrition status
mutate(
malnutrition_status = case_when(
malnutrition_whz  == "Severe Acute Malnutrition (SAM)" |
malnutrition_muac == "Severe Acute Malnutrition (SAM)" ~ "Severe Acute Malnutrition (SAM)",
malnutrition_whz  == "Moderate Acute Malnutrition (MAM)" |
malnutrition_muac == "Moderate Acute Malnutrition (MAM)" ~ "Moderate Acute Malnutrition (MAM)",
malnutrition_whz  == "Normal" &
malnutrition_muac == "Normal" ~ "Normal",
TRUE ~ NA_character_
)
) |>
# Stunting classification using HAZ
mutate(
stunting_status = case_when(
haz <  -3              ~ "Severe stunting",
haz >= -3 & haz < -2  ~ "Moderate stunting",
haz >= -2              ~ "Normal",
TRUE ~ NA_character_
)
) |>
mutate(
study_arm = ifelse(
village %in% arm1_villages, "Intervention arm 1",
ifelse(village %in% arm2_villages, "Intervention arm 2", "Control arm")
),
visit_type = factor(
visit_type,
levels = c("Baseline", "Six Weeks Follow-up", "Quarterly Follow-up")
),
season = classify_season(interview_date)
) |>
select(
number_0, chld_dob, gendrchld,
sublocation, village, household_id,
interview_date, study_arm, visit_type,
age_months, age_group, season,
chldhght, chldwght, chld_muac,
whz, haz,
malnutrition_whz, malnutrition_muac, malnutrition_status,
stunting_status,
brstfd, hlthprblmschld
) |>
distinct()
message(sprintf("  → Child nutritional status: %d records, %d children",
nrow(child_nutritional_status),
n_distinct(child_nutritional_status$number_0)))
# export
write_csv(child_nutritional_status, "outputs/child_nutritional_status.csv")
mother_anthro_raw <- read_csv("/Users/cema/Documents/cema/Muema/L4H_diet_diversity/baseline/baseline_mthr_anthro_20201023.csv",
na = "---",
show_col_types = FALSE) |>
clean_names()
# clean
mother_anthro_corrected <- mother_anthro_raw |>
mutate(
mothrmuac = ifelse(mothrmuac == 6.9,  16.9, mothrmuac),
mothrmuac = ifelse(mothrmuac == 55.9, 23.5, mothrmuac),
mothrmuac = ifelse(mothrmuac == 48.0, 24.7, mothrmuac),
mothrmuac = ifelse(mothrmuac == 99,   NA,   mothrmuac)
)
# load the baseline mother questionnaire
mother_questionnaire_raw <- read_csv('/Users/cema/Documents/cema/Muema/L4H_diet_diversity/baseline/baseline_mother_20201023.csv',
na = "---",
show_col_types = FALSE) |>
clean_names()
# join the two baseline mother datasets
# number_0 in both files links to number in individual_baseline
# which gives us household_id, village, and interview date
mother_baseline_joined <- mother_questionnaire_raw |>
select(number_0, studyprticipnts, amntmilk, amntboildmlk) |>
left_join(
mother_anthro_corrected |>
select(number_0, mthrwght, mothrmuac),
by = "number_0"
) |>
# join to individual baseline to get household location and date
# number_0 in the mother files = number in individual_baseline
left_join(
individual_baseline |>
select(number, sublocation, village, household_id,
interview_date, study_arm, visit_number),
by = c("number_0" = "number")
) |>
mutate(visit_type = "Baseline") |>
distinct()
# load follow-up maternal MUAC data
# six-week maternal MUAC
sixweek_mother_status_raw <- read_csv("/Users/cema/Documents/cema/Muema/L4H_diet_diversity/L4H_Six weeks follow up questionnaire/follow up one.csv",
na = "---") |>
rename_all(~ str_replace(., "^form.mothrsques.", "")) |>
clean_names()
sixweek_mother_status <- sixweek_mother_status_raw |>
select(
number, sublocation, village, household_id,
interview_date, visit_number,
any_of("mothrmuac")
) |>
mutate(
interview_date = ymd(interview_date),
study_arm = ifelse(
village %in% arm1_villages, "1",
ifelse(village %in% arm2_villages, "2", "3")
),
visit_type = "Six Weeks Follow-up"
) |>
distinct()
# quarterly maternal MUAC
quart_mother_status <- individual_quart |>
select(
household_id, interview_date, study_arm,
any_of("mothr_mothrmuac")
) |>
mutate(visit_type = "Quarterly Follow-up") |>
distinct()
# combine
mother_nutritional_status <- bind_rows(
mother_baseline_joined |>
select(number_0, sublocation, village, household_id,
interview_date, study_arm, visit_type, mothrmuac),
sixweek_mother_status |>
rename(number_0 = number),
quart_mother_status
) |>
mutate(
study_arm = ifelse(
village %in% arm1_villages, "Intervention arm 1",
ifelse(village %in% arm2_villages, "Intervention arm 2", "Control arm")
),
visit_type = factor(
visit_type,
levels = c("Baseline", "Six Weeks Follow-up", "Quarterly Follow-up")
),
# Maternal malnutrition classification
malnutrition_status = case_when(
mothrmuac <  21                        ~ "Severe Acute Malnutrition",
mothrmuac >= 21 & mothrmuac <  23      ~ "Moderate Acute Malnutrition",
mothrmuac >= 23                        ~ "Normal",
TRUE ~ NA_character_
),
season = classify_season(interview_date)
) |>
select(
household_id, sublocation, village, study_arm,
interview_date, visit_type, season,
mothrmuac, malnutrition_status
) |>
distinct()
message(sprintf("  → Mother nutritional status: %d records, %d households",
nrow(mother_nutritional_status),
n_distinct(mother_nutritional_status$household_id)))
# export
#write_csv(mother_nutritional_status, "outputs/mother_nutritional_status.csv")
# Longitudinal dataset ----------------------------------------------------
longitudinal_combined <- bind_rows(
baseline_hh   |> mutate(data_source = "Baseline",   across(everything(), as.character)),
sixweek_hh    |> mutate(data_source = "Six Weeks",  across(everything(), as.character)),
quart_hh      |> mutate(data_source = "Quarterly",  across(everything(), as.character))
)
message(sprintf("  → Stacked: %d rows before cleaning", nrow(longitudinal_combined)))
longitudinal_typed <- longitudinal_combined |>
mutate(
interview_date = as_date(interview_date),
visit          = as.integer(visit),
hh_eligible = case_when(
hh_eligible %in% c("1", "Yes") ~ 1L,
hh_eligible %in% c("0", "No")  ~ 0L,
TRUE ~ NA_integer_
),
across(
c(hhpple, mle_hh,
total_births, total_deaths, total_sales,
total_purchases, total_sick,
total_milk_litres, total_lactating,
herd_size),
~ suppressWarnings(as.numeric(.x))
)
)
## apply the study cutoff date
longitudinal_filtered <- longitudinal_typed |>
filter(!is.na(household_id), !is.na(interview_date)) |>
#filter(interview_date <= cutoff_date)
message(sprintf("  → After cutoff filter: %d rows", nrow(longitudinal_filtered)))
## apply the study cutoff date
longitudinal_filtered <- longitudinal_typed |>
filter(!is.na(household_id), !is.na(interview_date)) |>
#filter(interview_date <= cutoff_date)
message(sprintf("  → After cutoff filter: %d rows", nrow(longitudinal_filtered)))
longitudinal_filtered <- longitudinal_typed |>
filter(!is.na(household_id), !is.na(interview_date))
## apply the study cutoff date
longitudinal_filtered <- longitudinal_typed |>
filter(!is.na(household_id), !is.na(interview_date)) |>
#filter(interview_date <= cutoff_date)
message(sprintf("  → After cutoff filter: %d rows", nrow(longitudinal_filtered)))
## apply the study cutoff date
longitudinal_filtered <- longitudinal_typed |>
filter(!is.na(household_id), !is.na(interview_date))
message(sprintf("  → After cutoff filter: %d rows", nrow(longitudinal_filtered)))
## remove duplicates
longitudinal_deduped <- longitudinal_filtered |>
distinct(household_id, interview_date, visit_type, .keep_all = TRUE)
message(sprintf("  → After deduplication: %d rows", nrow(longitudinal_deduped)))
## sort chronologically within each household
longitudinal_ordered <- longitudinal_deduped |>
arrange(household_id, interview_date) |>
group_by(household_id) |>
mutate(visit_seq = row_number()) |>
ungroup()
## add season labels
longitudinal <- longitudinal_ordered |>
mutate(
visit_type = factor(
visit_type,
levels = c("Baseline", "Six Weeks Follow-up", "Quarterly Follow-up")
),
season = classify_season(interview_date)
) |>
# bring the most important columns to the front for readability
relocate(
household_id, village, sublocation, study_arm,
interview_date, visit, visit_type, visit_seq, season,
data_source, hh_eligible
)
message(sprintf(
"  → Longitudinal dataset ready: %d rows | %d households | %s to %s",
nrow(longitudinal),
n_distinct(longitudinal$household_id),
min(longitudinal$interview_date, na.rm = TRUE),
max(longitudinal$interview_date, na.rm = TRUE)
))
# export
write_csv(longitudinal, "/Users/cema/Downloads/L4H_longitudinal_dataset.csv")
# export
write_csv(longitudinal, "/Users/cema/Documents/cema/Muema/L4H_longitudinal_dataset.csv")
